{
  "name": "lovable-bridge",
  "version": "0.2.1",
  "private": true,
  "description": "Lovable Bridge — 本机守护进程，转发 Cloud ↔ FutuOpenD",
  "scripts": {
    "dev": "bun run index.ts",
    "build:win":     "bun build --compile --target=bun-windows-x64  --outfile=dist/LovableBridge.exe index.ts",
    "build:mac-arm": "bun build --compile --target=bun-darwin-arm64 --outfile=dist/LovableBridge-mac-arm64 index.ts",
    "build:mac-x64": "bun build --compile --target=bun-darwin-x64  --outfile=dist/LovableBridge-mac-x64 index.ts",
    "build:linux":   "bun build --compile --target=bun-linux-x64   --outfile=dist/LovableBridge-linux-x64 index.ts",
    "build:all":     "bash scripts/build-all.sh"
  },
  "dependencies": {
    "futu-api": "^10.6.6608",
    "protobufjs": "^7.4.0",
    "long": "^5.2.3"
  }
}