{
  "name": "lovable-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Lovable Bridge — 本机守护进程，转发 Cloud ↔ FutuOpenD",
  "scripts": {
    "dev": "bun run index.ts",
    "build:win":     "bun build index.ts --compile --target=bun-windows-x64  -o dist/LovableBridge.exe",
    "build:mac-arm": "bun build index.ts --compile --target=bun-darwin-arm64 -o dist/LovableBridge-mac-arm64",
    "build:mac-x64": "bun build index.ts --compile --target=bun-darwin-x64  -o dist/LovableBridge-mac-x64",
    "build:linux":   "bun build index.ts --compile --target=bun-linux-x64   -o dist/LovableBridge-linux-x64",
    "build:all":     "bash scripts/build-all.sh"
  },
  "optionalDependencies": {
    "futu-api": "*"
  }
}